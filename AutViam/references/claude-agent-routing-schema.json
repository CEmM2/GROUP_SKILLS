{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AutViam Claude agent routing policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "policy_version", "models", "base_tier_by_score",
    "profiles_by_role_and_tier", "special_routes", "capabilities",
    "spawn_edges", "purpose_roles", "ticket_ttl_seconds"
  ],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": 1},
    "policy_version": {"type": "string", "minLength": 1},
    "models": {"type": "object"},
    "base_tier_by_score": {"type": "object"},
    "profiles_by_role_and_tier": {"type": "object"},
    "special_routes": {"type": "object"},
    "capabilities": {"type": "object"},
    "spawn_edges": {"type": "object"},
    "purpose_roles": {"type": "object"},
    "ticket_ttl_seconds": {"type": "integer", "minimum": 1}
  }
}
